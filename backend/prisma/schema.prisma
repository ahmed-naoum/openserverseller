// Silacod.ma - PostgreSQL Production Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  guardName String   @default("web")
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("roles")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_resets")
}

model User {
  id       Int     @id @default(autoincrement())
  uuid     String  @unique @default(uuid())
  email    String? @unique
  phone    String? @unique
  password String
  roleId   Int
  role     Role    @relation(fields: [roleId], references: [id])

  // Seller-Affiliate mode switching
  mode String @default("SELLER") // SELLER, AFFILIATE

  // Influencer fields
  referralCode  String? @unique
  isInfluencer  Boolean @default(false)
  totalEarnings Float   @default(0)

  isActive        Boolean   @default(false)
  kycStatus       String    @default("PENDING")
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  lastLoginAt     DateTime?

  // 2FA and SSO
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean @default(false)
  googleId           String? @unique

  // Tracking
  registrationIp String?
  detectedCity   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Contract Status
  contractAccepted Boolean   @default(false)
  contractSignedAt DateTime?

  profile        UserProfile?
  kycDocuments   KycDocument[]
  brands         Brand[]
  leadImports    LeadImportBatch[]
  leads          Lead[]
  assignedLeads  Lead[]            @relation("AgentLeads")
  orders         Order[]
  wallet         Wallet?
  payoutRequests PayoutRequest[]   @relation("VendorPayouts")
  notifications  Notification[]

  ownedProducts   Product[]          @relation("ProductOwner")
  inventory       ProductInventory[]
  claims          AffiliateClaim[]
  supportRequests SupportRequest[]

  conversations ConversationParticipant[]
  messages      Message[]
  activityLogs  ActivityLog[]

  // Agent/Lead management relations
  leadStatusHistories LeadStatusHistory[]
  callLogs            CallLog[]
  leadAssignments     LeadAssignment[]

  // Influencer relations
  referralLinks ReferralLink[]
  commissions   InfluencerCommission[]

  // Agent-Influencer assignment relations
  agentAssignments      AgentInfluencerAssignment[] @relation("AgentAssignments")
  influencerAssignments AgentInfluencerAssignment[] @relation("InfluencerAssignments")

  orderStatusHistories OrderStatusHistory[]
  productionJobs       ProductionJob[]
  favorites            Favorite[]
  targetedAnnouncements Announcement[]     @relation("TargetedAnnouncements")

  @@map("users")
}

model UserProfile {
  userId    Int     @id
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String?
  avatarUrl String?
  city      String?
  address   String?
  language  String  @default("fr")
  metadata  Json?

  // Influencer Specific
  instagramUsername  String?
  instagramFollowers Int?
  tiktokUsername     String?
  facebookUsername   String?
  xUsername          String?
  youtubeUsername    String?
  snapchatUsername   String?

  @@map("user_profiles")
}

model KycDocument {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  documentType String
  documentUrl  String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  @@map("kyc_documents")
}

model Brand {
  id             Int       @id @default(autoincrement())
  vendorId       Int
  vendor         User      @relation(fields: [vendorId], references: [id])
  name           String
  slug           String    @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  slogan         String?
  description    String?
  designSettings String?
  isApproved     Boolean   @default(false)
  approvedAt     DateTime?
  status         String    @default("DRAFT")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bankAccounts BrandBankAccount[]
  leads        Lead[]
  orders       Order[]

  @@map("brands")
}

model BrandBankAccount {
  id         Int     @id @default(autoincrement())
  brandId    Int
  brand      Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  bankName   String
  ribAccount String
  iceNumber  String?
  isPrimary  Boolean @default(false)

  @@map("brand_bank_accounts")
}

model Category {
  id       Int        @id @default(autoincrement())
  nameAr   String
  nameFr   String
  nameEn   String?
  parentId Int?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  slug     String     @unique
  imageUrl String?
  products Product[]

  @@map("categories")
}

model Product {
  id              Int     @id @default(autoincrement())
  sku             String  @unique
  ref             String? @unique // URL-friendly reference string
  nameAr          String
  nameFr          String
  nameEn          String?
  description     String?
  longDescription String? // Rich HTML content

  categories Category[] // Implicit M-To-M relation

  baseCostMad        Float
  retailPriceMad     Float
  affiliatePriceMad  Float?
  influencerPriceMad Float?
  isCustomizable     Boolean @default(true)
  minProductionDays  Int     @default(3)
  stockQuantity      Int     @default(0)
  stockStatus        String  @default("available") // "available", "out_of_stock", "pre_order"

  // Downloads and Links
  ficheTechniqueUrl  String?
  canvaLink         String?
  mockupLink        String?

  // Arch modifications
  ownerId         Int?
  owner           User?    @relation("ProductOwner", fields: [ownerId], references: [id])
  visibility      String[] @default(["REGULAR"]) // REGULAR, AFFILIATE, INFLUENCER, NONE
  status          String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  videoUrls       String[] @default([])
  landingPageUrls String[] @default([])
  commissionMad           Float    @default(0) // Affiliate commission per sale in MAD
  influencerCommissionMad Float    @default(0) // Influencer commission per sale in MAD

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images               ProductImage[]
  orderItems           OrderItem[]
  inventories          ProductInventory[]
  warehouseInventories Inventory[]
  brandCustomizations  BrandProductCustomization[]
  claims               AffiliateClaim[]
  referralLinks        ReferralLink[]
  supportRequests      SupportRequest[]
  wholesalePrices      WholesalePriceTier[]
  favorites            Favorite[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  @@map("product_images")
}

model WholesalePriceTier {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQuantity  Int
  maxQuantity  Int
  pricePerUnit Float
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("wholesale_price_tiers")
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}

model PlatformSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique // e.g. "site_name", "fees", "media"
  value     Json
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model LeadImportBatch {
  id            Int      @id @default(autoincrement())
  vendorId      Int
  vendor        User     @relation(fields: [vendorId], references: [id])
  fileName      String
  totalRows     Int      @default(0)
  validRows     Int      @default(0)
  duplicateRows Int      @default(0)
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  leads Lead[]

  @@map("lead_import_batches")
}

model Lead {
  id              Int              @id @default(autoincrement())
  vendorId        Int
  vendor          User             @relation(fields: [vendorId], references: [id])
  brandId         Int?
  brand           Brand?           @relation(fields: [brandId], references: [id])
  importBatchId   Int?
  importBatch     LeadImportBatch? @relation(fields: [importBatchId], references: [id])
  fullName        String
  phone           String
  whatsapp        String?
  city            String?
  address         String?
  status          String           @default("NEW")
  assignedAgentId Int?
  assignedAgent   User?            @relation("AgentLeads", fields: [assignedAgentId], references: [id])
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  order          Order?
  referralLinkId Int?
  referralLink   ReferralLink?       @relation(fields: [referralLinkId], references: [id])
  statusHistory  LeadStatusHistory[]
  callLogs       CallLog[]
  assignments    LeadAssignment[]

  @@map("leads")
}

model LeadStatusHistory {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id])
  oldStatus String
  newStatus String
  changedBy Int
  changer   User     @relation(fields: [changedBy], references: [id])
  notes     String?
  createdAt DateTime @default(now())

  @@map("lead_status_history")
}

model CallLog {
  id                  Int      @id @default(autoincrement())
  leadId              Int
  lead                Lead     @relation(fields: [leadId], references: [id])
  agentId             Int
  agent               User     @relation(fields: [agentId], references: [id])
  callDurationSeconds Int?
  outcome             String // ANSWERED, NO_ANSWER, BUSY, etc.
  recordingUrl        String?
  notes               String?
  createdAt           DateTime @default(now())

  @@map("call_logs")
}

model LeadAssignment {
  id           Int       @id @default(autoincrement())
  leadId       Int
  lead         Lead      @relation(fields: [leadId], references: [id])
  agentId      Int
  agent        User      @relation(fields: [agentId], references: [id])
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  @@map("lead_assignments")
}

model Order {
  id               Int      @id @default(autoincrement())
  orderNumber      String   @unique
  vendorId         Int
  vendor           User     @relation(fields: [vendorId], references: [id])
  brandId          Int
  brand            Brand    @relation(fields: [brandId], references: [id])
  leadId           Int?     @unique
  lead             Lead?    @relation(fields: [leadId], references: [id])
  customerName     String
  customerPhone    String
  customerCity     String
  customerAddress  String
  totalAmountMad   Float
  vendorEarningMad Float
  platformFeeMad   Float
  status              String   @default("PENDING")
  paymentMethod       String   @default("COD")
  coliatyPackageCode  String?
  coliatyPackageId    Int?
  packageContent      String?
  packageNoOpen       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  items                 OrderItem[]
  walletTransactions    WalletTransaction[]
  influencerCommissions InfluencerCommission[]
  statusHistory         OrderStatusHistory[]
  shipment              Shipment?
  returns               OrderReturn[]
  productionJobs        ProductionJob[]

  @@map("orders")
}

model OrderItem {
  id              Int                        @id @default(autoincrement())
  orderId         Int
  order           Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product                    @relation(fields: [productId], references: [id])
  quantity        Int
  unitPriceMad    Float
  totalPriceMad   Float
  customizationId Int?
  customization   BrandProductCustomization? @relation(fields: [customizationId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id            Int      @id @default(autoincrement())
  orderId       Int
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  oldStatus     String?
  newStatus     String
  changedBy     Int
  changedByUser User     @relation(fields: [changedBy], references: [id])
  notes         String?
  createdAt     DateTime @default(now())

  @@map("order_status_history")
}

model BrandProductCustomization {
  id             Int         @id @default(autoincrement())
  brandId        Int
  productId      Int
  product        Product     @relation(fields: [productId], references: [id])
  name           String
  options        Json?
  customPriceMad Float?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]

  @@map("brand_product_customizations")
}

model Warehouse {
  id        Int               @id @default(autoincrement())
  name      String
  location  String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  batches   ProductionBatch[]
  inventory Inventory[]

  @@map("warehouses")
}

model ProductionBatch {
  id          Int             @id @default(autoincrement())
  batchNumber String          @unique
  warehouseId Int
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id])
  status      String          @default("PENDING")
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  jobs        ProductionJob[]

  @@map("production_batches")
}

model ProductionJob {
  id           Int             @id @default(autoincrement())
  batchId      Int
  batch        ProductionBatch @relation(fields: [batchId], references: [id])
  orderId      Int
  order        Order           @relation(fields: [orderId], references: [id])
  status       String          @default("PENDING")
  assignedTo   Int?
  assignedUser User?           @relation(fields: [assignedTo], references: [id])
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@map("production_jobs")
}

model Inventory {
  id               Int       @id @default(autoincrement())
  warehouseId      Int
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  productId        Int
  product          Product   @relation(fields: [productId], references: [id])
  quantity         Int       @default(0)
  reservedQuantity Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@map("inventories")
}

model Courier {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  isActive  Boolean    @default(true)
  shipments Shipment[]

  @@map("couriers")
}

model Shipment {
  id             Int                     @id @default(autoincrement())
  orderId        Int                     @unique
  order          Order                   @relation(fields: [orderId], references: [id])
  courierId      Int
  courier        Courier                 @relation(fields: [courierId], references: [id])
  trackingNumber String?                 @unique
  status         String                  @default("PENDING")
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  trackingEvents ShipmentTrackingEvent[]
  deliveryProof  ShipmentDeliveryProof?

  @@map("shipments")
}

model ShipmentTrackingEvent {
  id         Int      @id @default(autoincrement())
  shipmentId Int
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  status     String
  location   String?
  eventTime  DateTime @default(now())
  notes      String?

  @@map("shipment_tracking_events")
}

model ShipmentDeliveryProof {
  id         Int      @id @default(autoincrement())
  shipmentId Int      @unique
  shipment   Shipment @relation(fields: [shipmentId], references: [id])
  imageUrl   String
  signedBy   String?
  createdAt  DateTime @default(now())

  @@map("shipment_delivery_proofs")
}

model OrderReturn {
  id        Int      @id @default(autoincrement())
  orderId   Int
  order     Order    @relation(fields: [orderId], references: [id])
  reason    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@map("order_returns")
}

model Wallet {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceMad        Float    @default(0)
  totalEarnedMad    Float    @default(0)
  totalWithdrawnMad Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id              Int      @id @default(autoincrement())
  walletId        Int
  wallet          Wallet   @relation(fields: [walletId], references: [id])
  type            String
  amountMad       Float
  balanceAfterMad Float
  description     String?
  orderId         Int?
  order           Order?   @relation(fields: [orderId], references: [id])
  createdAt       DateTime @default(now())

  @@map("wallet_transactions")
}

model PayoutRequest {
  id          Int       @id @default(autoincrement())
  vendorId    Int
  vendor      User      @relation("VendorPayouts", fields: [vendorId], references: [id])
  amountMad   Float
  status      String    @default("PENDING")
  bankName    String
  ribAccount  String
  iceNumber   String?
  processedAt DateTime?
  receiptUrl  String?
  createdAt   DateTime  @default(now())

  @@map("payout_requests")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Announcement {
  id           Int      @id @default(autoincrement())
  type         String   // GLOBAL, ROLE, USER
  severity     String   @default("INFO") // INFO, WARNING, IMPORTANT
  priority     Int      @default(0)
  placement    String   @default("TOP")  // TOP, BOTTOM
  targetRole   String?  // e.g., 'VENDOR', 'INFLUENCER', 'AGENT'
  targetUserId Int?     
  targetUser   User?    @relation("TargetedAnnouncements", fields: [targetUserId], references: [id], onDelete: Cascade)
  title        String
  content      String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("announcements")
}

model MoroccanCity {
  id      Int     @id @default(autoincrement())
  nameAr  String
  nameFr  String  @unique
  nameEn  String?
  region  String?
  isMajor Boolean @default(false)

  @@map("moroccan_cities")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  modelType String?
  modelId   Int?
  changes   String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model ProductInventory {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int      @default(0)
  acquiredAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("product_inventory")
}

model AffiliateClaim {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, REVOKED
  claimedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("affiliate_claims")
}

model SupportRequest {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  type        String // DELIVERY_FULFILLMENT, PRODUCT_CLAIM, senior_SUPPORT, etc.
  subject     String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_requests")
}

// ==========================================
// CHAT & MESSAGING SYSTEM
// ==========================================

model Conversation {
  id        Int      @id @default(autoincrement())
  type      String   @default("DIRECT") // DIRECT, GROUP, SUPPORT
  title     String? // Optional for groups/support
  status    String   @default("ACTIVE") // ACTIVE, ARCHIVED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("MEMBER") // MEMBER, ADMIN
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  messageType    String       @default("TEXT") // TEXT, IMAGE, FILE, SYSTEM
  attachmentUrl  String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("messages")
}

// ==========================================
// INFLUENCER SYSTEM
// ==========================================

model ReferralLink {
  id           Int      @id @default(autoincrement())
  influencerId Int
  influencer   User     @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  code         String   @unique
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  earnings     Float    @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  commissions InfluencerCommission[]
  leads       Lead[]

  @@unique([influencerId, productId])
  @@map("referral_links")
}

model InfluencerCampaign {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  productIds  Int[] // Array of product IDs
  commission  Float // Percentage (e.g., 10 = 10%)
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, ENDED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("influencer_campaigns")
}

model InfluencerCommission {
  id             Int          @id @default(autoincrement())
  influencerId   Int
  influencer     User         @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  referralLinkId Int
  referralLink   ReferralLink @relation(fields: [referralLinkId], references: [id])
  orderId        Int?
  order          Order?       @relation(fields: [orderId], references: [id])
  amount         Float
  status         String       @default("PENDING") // PENDING, APPROVED, PAID
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  @@map("influencer_commissions")
}

// ==========================================
// AGENT-INFLUENCER ASSIGNMENT
// ==========================================

model AgentInfluencerAssignment {
  id           Int      @id @default(autoincrement())
  agentId      Int
  agent        User     @relation("AgentAssignments", fields: [agentId], references: [id], onDelete: Cascade)
  influencerId Int
  influencer   User     @relation("InfluencerAssignments", fields: [influencerId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())

  @@unique([agentId, influencerId])
  @@map("agent_influencer_assignments")
}

// ==========================================
// WEBHOOK LOGS
// ==========================================

model WebhookLog {
  id        Int      @id @default(autoincrement())
  provider  String   // e.g., "COLIATY"
  payload   Json     // Raw request body
  processed Boolean  @default(false)
  status    String?  // Processing status or error state
  errorMsg  String?
  createdAt DateTime @default(now())

  @@map("webhook_logs")
}
