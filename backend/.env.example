# ============================================
# Silacod.ma - Environment Variables
# Development Configuration
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:yourpasshere@localhost:5432/silacod_db"

# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# Authentication
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# SMTP / Email Config
SMTP_HOST=mail.silacod.com
SMTP_PORT=587
SMTP_USER=mailuser
SMTP_PASS=
SMTP_SECURE=true
SMTP_FROM_EMAIL=mail@silacod.com
EMAIL_FROM=mail@silacod.com

# IMAP Config (for reference)
IMAP_HOST=mail.silacod.com
IMAP_PORT=143
IMAP_USER=mailuser
IMAP_PASS=

# Coliaty Delivery API
COLIATY_PUBLIC_KEY=
COLIATY_SECRET_KEY=
COLIATY_BASE_URL=https://customer-api-v1.coliaty.com
