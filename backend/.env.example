# Environment
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# Database
DATABASE_URL="postgresql://openseller:openseller123@localhost:5432/openseller?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# File Storage (S3 or local)
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-3
AWS_S3_BUCKET=openseller

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@openseller.ma

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# Courier APIs
COLISWIFT_API_KEY=
COLISWIFT_API_URL=https://api.coliswift.ma
ARAMEX_API_KEY=
ARAMEX_API_URL=https://api.aramex.com

# Platform Settings
PLATFORM_COMMISSION_PERCENTAGE=15
MIN_PAYOUT_AMOUNT_MAD=500

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
