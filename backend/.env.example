# ============================================
# Silacod.ma - Environment Variables
# Development Configuration
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password123@localhost:5432/silacod_db"

# Server
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173

# Authentication
JWT_SECRET=dev_secret_key_change_in_production_64_chars_long_string_1234567890
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# SMTP / Email Config
SMTP_HOST=mail.silacod.com
SMTP_PORT=587
SMTP_USER=mailuser
SMTP_PASS=mailpassword123
SMTP_SECURE=true
SMTP_FROM_EMAIL=mail@silacod.com
EMAIL_FROM=mail@silacod.com

# IMAP Config (for reference)
IMAP_HOST=mail.silacod.com
IMAP_PORT=143
IMAP_USER=mailuser
IMAP_PASS=mailpassword123