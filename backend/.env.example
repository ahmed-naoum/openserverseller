# ============================================
# Silacod.ma - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://silacod:YOUR_PASSWORD@localhost:5432/silacod_db"

# Server
NODE_ENV=production
PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=https://yourdomain.com

# Authentication
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379
